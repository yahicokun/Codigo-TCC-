# 2. CLASSE DA REDE NEURAL OTIMIZADA
# ============================================
class OptimizedMBTR_MLP(nn.Module):
    def __init__(self, input_size, hidden_sizes, activation='relu', 
                 dropout_rate=0.3, use_batch_norm=True):
        """
        MLP com arquitetura otimizada pelo Optuna
        
        Args:
            input_size: Número de features de entrada
            hidden_sizes: Lista com tamanhos das camadas ocultas
            activation: Função de ativação ('relu', 'tanh', 'sigmoid')
            dropout_rate: Taxa de dropout (0 para desativar)
            use_batch_norm: Se True, usa batch normalization
        """
        super(OptimizedMBTR_MLP, self).__init__()
        
        layers = []
        prev_size = input_size
        
        print(f"\n Construindo rede neural otimizada:")
        print(f"   Arquitetura: {hidden_sizes}")
        print(f"   Ativação: {activation}")
        print(f"   Dropout: {dropout_rate}")
        print(f"   Batch Norm: {use_batch_norm}")
        
        # Construir camadas
        for i, hidden_size in enumerate(hidden_sizes):
            # Camada linear
            layers.append(nn.Linear(prev_size, hidden_size))
            
            # Batch normalization
            if use_batch_norm:
                layers.append(nn.BatchNorm1d(hidden_size))
            
            # Função de ativação
            if activation == 'relu':
                layers.append(nn.ReLU())
            elif activation == 'tanh':
                layers.append(nn.Tanh())
            elif activation == 'sigmoid':
                layers.append(nn.Sigmoid())
            elif activation == 'leaky_relu':
                layers.append(nn.LeakyReLU(0.01))
            else:
                layers.append(nn.ReLU())
            
            # Dropout (apenas se rate > 0)
            if dropout_rate > 0:
                layers.append(nn.Dropout(dropout_rate))
            
            prev_size = hidden_size
        
        # Camada de saída
        layers.append(nn.Linear(prev_size, 1))
        
        self.model = nn.Sequential(*layers)
        
        # Inicialização dos pesos
        self._init_weights()
        
        # Contar parâmetros
        total_params = sum(p.numel() for p in self.parameters())
        trainable_params = sum(p.numel() for p in self.parameters() if p.requires_grad)
        
        print(f"✅ Rede construída!")
        print(f"   Parâmetros totais: {total_params:,}")
        print(f"   Parâmetros treináveis: {trainable_params:,}")
        
        # Salvar parâmetros de construção
        self.construction_params = {
            'input_size': input_size,
            'hidden_sizes': hidden_sizes,
            'activation': activation,
            'dropout_rate': dropout_rate,
            'use_batch_norm': use_batch_norm
        }
    
    def _init_weights(self):
        """Inicialização inteligente dos pesos"""
        for module in self.modules():
            if isinstance(module, nn.Linear):
                nn.init.kaiming_normal_(module.weight, mode='fan_in', nonlinearity='relu')
                if module.bias is not None:
                    nn.init.constant_(module.bias, 0)
            elif isinstance(module, nn.BatchNorm1d):
                nn.init.constant_(module.weight, 1)
                nn.init.constant_(module.bias, 0)
    
    def forward(self, x):
        return self.model(x)
    
    def get_architecture_info(self):
        """
        Retorna informações detalhadas sobre a arquitetura da rede
        
        Returns:
            dict: Dicionário com informações da arquitetura
        """
        # Extrair tamanhos das camadas ocultas
        hidden_sizes = []
        for layer in self.model:
            if isinstance(layer, nn.Linear) and layer.out_features != 1:
                hidden_sizes.append(layer.out_features)
        
        architecture_info = {
            'input_size': self.construction_params['input_size'],
            'hidden_sizes': hidden_sizes,
            'output_size': 1,
            'layers': [],
            'total_params': sum(p.numel() for p in self.parameters()),
            'trainable_params': sum(p.numel() for p in self.parameters() if p.requires_grad),
            'construction_params': self.construction_params
        }
        
        # Extrair informações de cada camada
        for i, layer in enumerate(self.model):
            layer_info = {
                'index': i,
                'type': layer.__class__.__name__,
                'parameters': sum(p.numel() for p in layer.parameters()) if hasattr(layer, 'parameters') else 0
            }
            
            if isinstance(layer, nn.Linear):
                layer_info.update({
                    'in_features': layer.in_features,
                    'out_features': layer.out_features,
                    'bias': layer.bias is not None
                })
            elif isinstance(layer, nn.BatchNorm1d):
                layer_info.update({
                    'num_features': layer.num_features,
                    'eps': layer.eps,
                    'momentum': layer.momentum,
                    'affine': layer.affine
                })
            elif isinstance(layer, (nn.ReLU, nn.Tanh, nn.Sigmoid, nn.LeakyReLU)):
                layer_info['activation'] = layer.__class__.__name__
                if isinstance(layer, nn.LeakyReLU):
                    layer_info['negative_slope'] = layer.negative_slope
            elif isinstance(layer, nn.Dropout):
                layer_info['p'] = layer.p
            
            architecture_info['layers'].append(layer_info)
        
        return architecture_info

