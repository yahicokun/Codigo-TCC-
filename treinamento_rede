def run_complete_mbtr_pipeline(json_path, db_path, target_key="gap", limit=100):
    """
    Pipeline completo: Geração Descritor + Treino Rede Neural
    
    Args:
        json_path: Caminho para arquivo JSON com parâmetros
        db_path: Caminho para banco de dados ASE
        target_key: Propriedade alvo
        limit: Limite de estruturas a processar
    
    Returns:
        trainer: Instância do treinador
        test_results: Resultados do teste
    """
    print("="*80)
    print("🚀 PIPELINE COMPLETO Descritor + REDE NEURAL")
    print("="*80)
    
    try:
        # 1. Inicializar treinador
        print("\n1️ INICIALIZANDO TREINADOR...")
        trainer = MBTR_MLP_Trainer(json_path)
        
        # 2. Gerar dados MBTR
        print("\n2️  GERANDO DESCRITORES MBTR...")
        X, y = trainer.generate_mbtr_data(db_path, target_key, limit)
        
        # 3. Preparar dados
        print("\n3️  PREPARANDO DADOS...")
        X_train, X_val, X_test, y_train, y_val, y_test = trainer.prepare_data(X, y)
        
        # 4. Construir modelo
        print("\n4️  CONSTRUINDO MODELO...")
        trainer.build_model(input_size=X_train.shape[1])
        
        # 5. Treinar
        print("\n5️  TREINANDO REDE NEURAL...")
        history = trainer.train(X_train, y_train, X_val, y_val)
        
        # 6. Avaliar
        print("\n6️  AVALIANDO PERFORMANCE...")
        test_results = trainer.evaluate(X_test, y_test)
        
        # 7. Gerar gráficos
        print("\n7️  GERANDO GRÁFICOS...")
        
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        plots_dir = f"plots_{timestamp}"
        os.makedirs(plots_dir, exist_ok=True)
        
        # Plot histórico
        trainer.plot_training_history(save_path=f"{plots_dir}/training_history.png")
        
        # Plot predições
        trainer.plot_predictions_vs_real(
            test_results,
            dataset_name='Teste',
            save_path=f"{plots_dir}/predictions_vs_real.png"
        )
        
        # 8. Salvar resultados
        print("\n8️  SALVANDO RESULTADOS...")
        model_path, results_path = trainer.save_results(
            test_results, 
            save_dir=f"results_{timestamp}"
        )
        
        # 9. Relatório final
        print("\n" + "="*80)
