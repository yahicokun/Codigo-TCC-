# 1. CLASSE PARA GERAÇÃO DOS DESCRITORES MBTR
# ============================================
class MBTR_Generator:
    def __init__(self, json_config_path):
        """
        Gera descritores MBTR usando parâmetros do JSON
        
        Args:
            json_config_path: Caminho para arquivo JSON com parâmetros otimizados
        """
        self.json_path = json_config_path
        self.config = self._load_config()
        self.descriptor = None
        
        print("🔧 Inicializando gerador MBTR...")
        self._print_mbtr_config()
    
    def _load_config(self):
        """Carrega configuração do JSON"""
        print(f"📂 Carregando configuração de: {self.json_path}")
        
        try:
            with open(self.json_path, 'r', encoding='utf-8') as f:
                config = json.load(f)
            print("✅ Configuração carregada com sucesso!")
            return config
        except Exception as e:
            print(f"❌ Erro ao carregar JSON: {e}")
            raise
    
    def _print_mbtr_config(self):
        """Imprime configuração MBTR"""
        if 'best_parameters' in self.config and 'mbtr' in self.config['best_parameters']:
            mbtr_params = self.config['best_parameters']['mbtr']
            print("\n📊 PARÂMETROS MBTR OBTIMIZADOS:")
            print("-" * 40)
            for key, value in mbtr_params.items():
                print(f"  {key}: {value}")
            print("-" * 40)
    
    def generate_mbtr_descriptor(self, species):
        """
        Cria o descritor MBTR com parâmetros otimizados
        
        Args:
            species: Lista de espécies químicas (ex: ['H', 'C', 'O'])
        
        Returns:
            Instância do descritor MBTR configurada
        """
        if 'best_parameters' not in self.config or 'mbtr' not in self.config['best_parameters']:
            raise ValueError("❌ Parâmetros MBTR não encontrados no JSON!")
        
        mbtr_params = self.config['best_parameters']['mbtr']
        
        print("\n🔧 Configurando descritor MBTR...")
        
        # Parâmetros obrigatórios
        required_params = ['grid_min', 'grid_max', 'grid_sigma', 'grid_n', 
                          'weighting_scale', 'weighting_threshold']
        
        for param in required_params:
            if param not in mbtr_params:
                print(f"⚠️  Parâmetro MBTR faltando: {param}, usando valor padrão")
        
        # Criar descritor MBTR com valores padrão
        try:
            self.descriptor = MBTR(
                species=species,
                geometry={"function": mbtr_params.get('geometry_function', 'atomic_number')},
                grid={
                    "min": mbtr_params.get('grid_min', 0),
                    "max": mbtr_params.get('grid_max', 10),
                    "sigma": mbtr_params.get('grid_sigma', 0.1),
                    "n": int(mbtr_params.get('grid_n', 100))
                },
                weighting={
                    "function": mbtr_params.get('weighting_function', 'unity'),
                    "scale": mbtr_params.get('weighting_scale', 0.5),
                    "threshold": mbtr_params.get('weighting_threshold', 1e-3)
                },
                normalization=mbtr_params.get('normalization', 'none'),
                periodic=mbtr_params.get('periodic', True),
                sparse=mbtr_params.get('sparse', False)
            )
            
            print("✅ Descritor MBTR configurado com sucesso!")
            return self.descriptor
        except Exception as e:
            print(f"❌ Erro ao criar descritor MBTR: {e}")
            raise
    
    def compute_descriptors_from_db(self, db_path, target_key="gap", limit=None):
        """
        Carrega banco de dados ASE e calcula descritores MBTR
        
        Args:
            db_path: Caminho para banco de dados ASE (.db)
            target_key: Chave da propriedade alvo (ex: "gap")
            limit: Limite de estruturas a processar (None para todas)
        
        Returns:
            X: Matriz de descritores (n_samples, n_features)
            y: Vetor de targets
        """
        print(f"\n📥 Carregando banco de dados: {db_path}")
        
        try:
            db = connect(db_path)
            # Modificação: usar select simples se a query falhar
            try:
                db_select = db.select(f"0<{target_key}<1000")
            except:
                print(f"⚠️  Query com filtro falhou, usando seleção simples")
                db_select = db.select()
            
            if limit:
                db_select = list(db_select)[:limit]
                print(f"⚠️  Limitando a {limit} estruturas para velocidade")
            else:
                db_select = list(db_select)
            
            structures = []
            targets = []
            species_set = set()
            
            print(f"🔧 Processando {len(db_select)} estruturas...")
            
            for i, row in enumerate(tqdm(db_select, desc="Estruturas")):
                try:
                    # Converter para objeto ASE Atoms
                    atoms = row.toatoms()
                    
                    # Coletar espécies
                    symbols = atoms.get_chemical_symbols()
                    species_set.update(symbols)
                    
                    structures.append({
                        'atoms': atoms,
                        'symbols': symbols,
                        'positions': atoms.get_positions(),
                        'lattice': atoms.cell.cellpar()
                    })
                    
                    # Coletar target
                    try:
                        target_value = eval(f'row.{target_key}')
                        targets.append(target_value)
                    except:
                        print(f"⚠️  Target '{target_key}' não encontrado na estrutura {i}")
                        targets.append(np.nan)
                    
                except Exception as e:
                    print(f"⚠️  Erro na estrutura {i}: {e}")
                    continue
            
            if not structures:
                raise ValueError("❌ Nenhuma estrutura processada com sucesso!")
            
            print(f"✅ {len(structures)} estruturas processadas")
            print(f"🔬 Espécies encontradas: {sorted(list(species_set))}")
            
            # Gerar descritor MBTR
            species_list = sorted(list(species_set))
            descriptor = self.generate_mbtr_descriptor(species_list)
            
            # Calcular descritores
            print("\n Calculando descritores ...")
            X_list = []
            valid_indices = []
            
            for i, struct in enumerate(tqdm(structures, desc="MBTR")):
                try:
                    # Usar sua função custom_bulk ou estrutura ASE diretamente
                    if hasattr(tools, 'custom_bulk'):
                        custom_structure = tools.custom_bulk(
                            struct['symbols'],
                            struct['positions'],
                            struct['lattice']
                        )
                        descriptor_vector = descriptor.create(custom_structure)
                    else:
                        descriptor_vector = descriptor.create(struct['atoms'])
                    
                    # Achatar o vetor
                    descriptor_flat = np.array(descriptor_vector).flatten()
                    X_list.append(descriptor_flat)
                    valid_indices.append(i)
                    
                except Exception as e:
                    print(f"⚠️  Erro no cálculo MBTR estrutura {i}: {e}")
                    continue
            
            # Converter para matriz
            X = np.array(X_list)
            
            # Filtrar targets para índices válidos
            y = np.array(targets)
            y = y[valid_indices]
            
            # Filtrar NaN em y
            valid_targets = ~np.isnan(y)
            X = X[valid_targets]
            y = y[valid_targets]
            
            print(f"\n✅ Descritores gerados com sucesso!")
            print(f"   Shape X: {X.shape}")
            print(f"   Shape y: {y.shape}")
            
            if len(y) == 0:
                raise ValueError(" Nenhum target válido encontrado!")
            
            # Estatísticas básicas
            print(f"   Estatísticas de y: min={y.min():.2f}, max={y.max():.2f}, "
                  f"mean={y.mean():.2f}, std={y.std():.2f}")
            
            return X, y
            
        except Exception as e:
            print(f" Erro ao processar banco de dados: {e}")
            raise

