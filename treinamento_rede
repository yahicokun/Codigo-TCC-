        # Texto com métricas
        textstr = (f'MSE = {results["mse"]:.4f}\n'
                  f'R² = {results["r2"]:.4f}\n'
                  f'MAE = {results["mae"]:.4f}\n'
                  f'Inclinação = {slope:.4f}')
        props = dict(boxstyle='round', facecolor='wheat', alpha=0.5)
        axes[0].text(0.05, 0.95, textstr, transform=axes[0].transAxes, fontsize=10,
