# 3. CLASSE DO TREINADOR COMPLETO
# ============================================
class MBTR_MLP_Trainer:
    def __init__(self, json_config_path, device=None):
        """
        
        Args:
            json_config_path: Caminho para arquivo JSON com parâmetros
            device: Dispositivo para treino (CPU/GPU)
        """
        self.device = device if device else torch.device('cuda' if torch.cuda.is_available() else 'cpu')
        self.json_path = json_config_path
        
        # Carregar configuração
        self.config = self._load_config()
        
        # Inicializar componentes
        self.mbtr_generator = None
        self.model = None
        self.scaler = StandardScaler()
        self.history = {
            'train_loss': [], 'val_loss': [], 'test_loss': [],
            'train_r2': [], 'val_r2': [], 'test_r2': [],
            'learning_rates': []
        }
        
        # Parâmetros de treino
        self.setup_training_params()
        
        print(f"\n🚀 Treinador inicializado no dispositivo: {self.device}")
    
    def _load_config(self):
        """Carrega configuração do JSON"""
        with open(self.json_path, 'r', encoding='utf-8') as f:
            return json.load(f)
    
    def setup_training_params(self):
        """Configura parâmetros de treino baseados no JSON"""
        # Valores padrão
        self.training_params = {
            'batch_size': 32,
            'num_epochs': 200,
            'patience': 100,
            'min_delta': 1e-4,
            'test_size': 0.15,
            'val_size': 0.15,
            'random_state': 42,
            'dropout_rate': 0.2,
            'use_batch_norm': True,
            'weight_decay': 1e-4
        }
        
        # Sobrescrever com valores do JSON se existirem
        if 'best_parameters' in self.config and 'mlp' in self.config['best_parameters']:
            mlp_params = self.config['best_parameters']['mlp']
            
            # Learning rate do JSON
            if 'learning_rate' in mlp_params:
                self.training_params['learning_rate'] = mlp_params['learning_rate']
            else:
                self.training_params['learning_rate'] = 0.001
        
        print("⚙️  Parâmetros de treino configurados")
    
    def generate_mbtr_data(self, db_path, target_key="gap", limit=None):
        """
        Gera dados MBTR a partir do banco de dados
        
        Args:
            db_path: Caminho para banco de dados ASE
            target_key: Propriedade alvo
            limit: Limite de estruturas
        
        Returns:
            X, y: Dados gerados
        """
        print("\n" + "="*60)
        print("🔬 GERANDO DESCRITORES MBTR")
        print("="*60)
        
        # Inicializar gerador MBTR
        self.mbtr_generator = MBTR_Generator(self.json_path)
        
        # Gerar descritores
        X, y = self.mbtr_generator.compute_descriptors_from_db(
            db_path, target_key, limit
        )
        
        # Salvar dados gerados
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        np.save(f"X_MBTR_GERADO_{timestamp}.npy", X)
        np.save(f"y_MBTR_GERADO_{timestamp}.npy", y)
        
        print(f"\n💾 Dados salvos:")
        print(f"   X_MBTR_GERADO_{timestamp}.npy")
        print(f"   y_MBTR_GERADO_{timestamp}.npy")
        
        return X, y
    
    def prepare_data(self, X, y):
        """
        Prepara dados para treino, validação e teste
        """
        print("\n📊 PREPARANDO DADOS PARA TREINO")
        
        # Verificar se há dados suficientes
        if len(X) < 10:
            raise ValueError(f"❌ Muito poucos dados: apenas {len(X)} amostras")
        
        # Split treino-teste
        X_temp, X_test, y_temp, y_test = train_test_split(
            X, y, 
            test_size=self.training_params['test_size'],
            random_state=self.training_params['random_state']
        )
        
        # Split treino-validação
        val_size_adj = self.training_params['val_size'] / (1 - self.training_params['test_size'])
        X_train, X_val, y_train, y_val = train_test_split(
            X_temp, y_temp,
            test_size=val_size_adj,
            random_state=self.training_params['random_state']
        )
        
        print(f"   Conjunto de Treino: {X_train.shape} ({len(X_train)} amostras)")
        print(f"   Conjunto de Validação: {X_val.shape} ({len(X_val)} amostras)")
        print(f"   Conjunto de Teste: {X_test.shape} ({len(X_test)} amostras)")
        
        # Normalização
        print("   Aplicando normalização...")
        self.scaler.fit(X_train)
        X_train_scaled = self.scaler.transform(X_train)
        X_val_scaled = self.scaler.transform(X_val)
        X_test_scaled = self.scaler.transform(X_test)
        
        # Converter para tensores
        X_train_t = torch.FloatTensor(X_train_scaled).to(self.device)
        X_val_t = torch.FloatTensor(X_val_scaled).to(self.device)
        X_test_t = torch.FloatTensor(X_test_scaled).to(self.device)
        y_train_t = torch.FloatTensor(y_train).to(self.device).view(-1, 1)
        y_val_t = torch.FloatTensor(y_val).to(self.device).view(-1, 1)
        y_test_t = torch.FloatTensor(y_test).to(self.device).view(-1, 1)
        
        return X_train_t, X_val_t, X_test_t, y_train_t, y_val_t, y_test_t
    
    def build_model(self, input_size):
        """
        Constrói o modelo MLP com parâmetros otimizados
        """
        print("\n🧠 CONSTRUINDO MODELO MLP")
        
        # Obter parâmetros do MLP do JSON
        if 'best_parameters' in self.config and 'mlp' in self.config['best_parameters']:
            mlp_params = self.config['best_parameters']['mlp']
            hidden_sizes = mlp_params.get('hidden_sizes', [64, 32])
            
            # Garantir que hidden_sizes é uma lista
            if isinstance(hidden_sizes, str):
                try:
                    hidden_sizes = eval(hidden_sizes)
                except:
                    hidden_sizes = [64, 32]
            elif isinstance(hidden_sizes, int):
                hidden_sizes = [hidden_sizes]
        else:
            hidden_sizes = [64, 32]
        
        # Construir modelo
        self.model = OptimizedMBTR_MLP(
            input_size=input_size,
            hidden_sizes=hidden_sizes,
            activation='relu',  # Pode ser ajustado se estiver no JSON
            dropout_rate=self.training_params['dropout_rate'],
            use_batch_norm=self.training_params['use_batch_norm']
        ).to(self.device)
        
        return self.model
    
    def train(self, X_train, y_train, X_val, y_val):
        """
        Treina o modelo com early stopping
        """
        print("\n🎯 INICIANDO TREINAMENTO")
        print("="*60)
        
        # Configurar otimizador
        optimizer = optim.Adam(
            self.model.parameters(),
            lr=self.training_params['learning_rate'],
            weight_decay=self.training_params.get('weight_decay', 0.0)
        )
        
        # CORREÇÃO: Remover o parâmetro 'verbose' do scheduler
        # Scheduler para learning rate
        try:
            # Tentar com verbose (PyTorch >= 1.4)
            scheduler = optim.lr_scheduler.ReduceLROnPlateau(
                optimizer, mode='min', patience=5, factor=0.5, verbose=True
            )
        except TypeError:
            # Fallback para versão sem verbose (PyTorch < 1.4)
            scheduler = optim.lr_scheduler.ReduceLROnPlateau(
                optimizer, mode='min', patience=5, factor=0.5
            )
            print("⚠️  PyTorch antigo detectado: verbose não disponível no scheduler")
        
        # Função de perda
        criterion = nn.MSELoss()
        
        # DataLoader
        train_dataset = TensorDataset(X_train, y_train)
        train_loader = DataLoader(
            train_dataset,
            batch_size=self.training_params['batch_size'],
            shuffle=True
        )
        
        # Early stopping
        best_val_loss = float('inf')
        patience_counter = 0
        best_model_state = None
        
        # Barra de progresso
        pbar = tqdm(range(self.training_params['num_epochs']), desc="Treinamento")
        
        for epoch in pbar:
            # Treino
            self.model.train()
            train_loss = 0.0
            
            for batch_X, batch_y in train_loader:
                optimizer.zero_grad()
                outputs = self.model(batch_X)
                loss = criterion(outputs, batch_y)
                loss.backward()
                optimizer.step()
                train_loss += loss.item()
            
            avg_train_loss = train_loss / len(train_loader)
            
            # Validação
            self.model.eval()
            with torch.no_grad():
                val_outputs = self.model(X_val)
                val_loss = criterion(val_outputs, y_val).item()
                
                # Calcular R²
                train_r2 = self._calculate_r2(self.model(X_train), y_train)
                val_r2 = self._calculate_r2(val_outputs, y_val)
            
            # Atualizar histórico
            self.history['train_loss'].append(avg_train_loss)
            self.history['val_loss'].append(val_loss)
            self.history['train_r2'].append(train_r2)
            self.history['val_r2'].append(val_r2)
            self.history['learning_rates'].append(optimizer.param_groups[0]['lr'])
            
            # Atualizar scheduler
            scheduler.step(val_loss)
            
            # Early stopping
            if val_loss < best_val_loss - self.training_params['min_delta']:
                best_val_loss = val_loss
                patience_counter = 0
                best_model_state = self.model.state_dict().copy()
                status = "✨ Melhoria"
            else:
                patience_counter += 1
                status = f"⏳ {patience_counter}/{self.training_params['patience']}"
            
            # Atualizar barra de progresso
            pbar.set_postfix({
                'Train Loss': f'{avg_train_loss:.4f}',
                'Val Loss': f'{val_loss:.4f}',
                'Val R²': f'{val_r2:.4f}',
                'Status': status
            })
            
            # Verificar early stopping
            if patience_counter >= self.training_params['patience']:
                print(f"\n⏹  Early stopping na época {epoch+1}")
                break
        
        # Restaurar melhor modelo
        if best_model_state:
            self.model.load_state_dict(best_model_state)
            print(f"✅ Melhor modelo restaurado (val loss: {best_val_loss:.6f})")
        
        print(f"\n✅ Treinamento concluído em {len(self.history['train_loss'])} épocas!")
        print(f"   Melhor val loss: {best_val_loss:.6f}")
        print(f"   Melhor val R²: {max(self.history['val_r2']):.6f}")
        
        return self.history
    
    def _calculate_r2(self, y_pred, y_true):
        """Calcula R² score"""
        y_pred_np = y_pred.cpu().detach().numpy().flatten()
        y_true_np = y_true.cpu().detach().numpy().flatten()
        return r2_score(y_true_np, y_pred_np)
    
    def evaluate(self, X_test, y_test):
        """
        Avalia o modelo no conjunto de teste
        """
        print("\n📊 AVALIAÇÃO NO CONJUNTO DE TESTE")
        print("-" * 40)
        
        self.model.eval()
        with torch.no_grad():
            y_pred = self.model(X_test)
            
            # Converter para numpy
            y_pred_np = y_pred.cpu().numpy().flatten()
            y_test_np = y_test.cpu().numpy().flatten()
            
            # Calcular métricas
            mse = mean_squared_error(y_test_np, y_pred_np)
            rmse = np.sqrt(mse)
            mae = mean_absolute_error(y_test_np, y_pred_np)
            r2 = r2_score(y_test_np, y_pred_np)
            
            # R² ajustado
            n = len(y_test_np)
            p = X_test.shape[1]
            r2_adj = 1 - (1 - r2) * (n - 1) / (n - p - 1)
            
            # MAPE
            y_test_abs = np.abs(y_test_np)
            mape_mask = y_test_abs > 1e-10
            if np.any(mape_mask):
                mape = np.mean(np.abs((y_test_np[mape_mask] - y_pred_np[mape_mask]) / y_test_np[mape_mask])) * 100
            else:
                mape = np.nan
            
            # Correlação de Pearson
            if len(y_test_np) > 1:
                pearson_corr, _ = stats.pearsonr(y_test_np, y_pred_np)
            else:
                pearson_corr = np.nan
        
        print("   Métricas de Performance:")
        print(f"   ├── MSE:  {mse:.6f}")
        print(f"   ├── RMSE: {rmse:.6f}")
        print(f"   ├── MAE:  {mae:.6f}")
        print(f"   ├── R²:   {r2:.6f} ({r2*100:.1f}% da variância explicada)")
        print(f"   ├── R² ajustado: {r2_adj:.6f}")
        print(f"   ├── MAPE: {mape:.2f}%")
        print(f"   └── Correlação de Pearson: {pearson_corr:.6f}")
        
        return {
            'y_true': y_test_np,
            'y_pred': y_pred_np,
            'mse': mse,
            'rmse': rmse,
            'mae': mae,
            'r2': r2,
            'r2_adj': r2_adj,
            'mape': mape,
            'pearson_corr': pearson_corr
        }
    
